# =============================================================================
# Steak Town — environment variables
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# In Vercel, add these under Project → Settings → Environment Variables.
# =============================================================================

# --- Supabase Postgres --------------------------------------------------------
# Get both strings from Supabase → Project Settings → Database → Connection string.
#
# DATABASE_URL = POOLED connection (Transaction pooler, port 6543) — used by the
#                app at runtime. Required for serverless (Vercel). Keep pgbouncer=true.
# DIRECT_URL   = DIRECT connection (Session, port 5432) — used by Prisma for
#                `db push` / migrations only.
#
# Replace [PROJECT-REF], [PASSWORD], and [REGION] with your project's values.

DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require"
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres?sslmode=require"

# --- NextAuth -----------------------------------------------------------------
# Generate a strong secret:  openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
# Local: http://localhost:3000 — Vercel: your deployed URL (https://your-app.vercel.app)
NEXTAUTH_URL="http://localhost:3000"

# --- First-time admin (dashboard login) --------------------------------------
# These seed the admin account AND allow the very first sign-in on a fresh
# database (bootstrap). Change them before going live.
ADMIN_EMAIL="admin@steaktown.qa"
ADMIN_PASSWORD="Admin@1234"
ADMIN_NAME="Steak Town Admin"
